# Configurações de Segurança e Integração da Meta/WhatsApp
# Variáveis ambientais nunca devem ser expostas (jamais commite o ".env" real para o Github).

# O APP_SECRET é exigido para calcular o HMAC-SHA256 e provar que a requisição veio realmente do WhatsApp
META_APP_SECRET="seu_app_secret_gigante_aqui"

# Token arbitrário que você define e insere no painel da Meta para sincronizar a URL do Webhook
WHATSAPP_VERIFY_TOKEN="sua_senha_forte_invulneravel_aqui"

# Token de acesso permanente (ou temporário) usado caso seu bot precise enviar mensagens ATIVAMENTE para usuários
WHATSAPP_ACCESS_TOKEN="seu_token_bearer_da_meta_aqui"

# Configuração do Servidor
FLASK_ENV="development"
PORT=5000
